local AllPets = {}

-- Add pets from InventoryDB
for id, info in pairs(InventoryDB.pets) do
    if info.name then
        table.insert(AllPets, {
            id = id,
            name = info.name,
            kind = info.kind
        })
    end
end

-- Function to find pet ID by name
local function FindPetId(petName)
    for id, info in pairs(InventoryDB.pets) do
        if info.name:lower() == petName:lower() then
            return id
        end
    end
    return nil
end

-- Add high tier pets
for _, petName in ipairs(HighTierPets) do
    local petId = FindPetId(petName)
    if petId then
        local alreadyAdded = false
        for _, pet in ipairs(AllPets) do
            if pet.name == petName then
                alreadyAdded = true
                break
            end
        end
        if not alreadyAdded then
            table.insert(AllPets, {
                id = petId,
                name = petName,
                kind = InventoryDB.pets[petId].kind
            })
        end
    end
end

