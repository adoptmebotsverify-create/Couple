local currentGift = nil
local currentPet = nil
local giftCount = 0

local function createCouplesGift()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then
        statusLabel.Text = "No character found!"
        return
    end
    
    local rootPart = character.HumanoidRootPart
    local playerPos = rootPart.Position
    local direction = rootPart.CFrame.LookVector
    
    -- Spawn position 5 studs in front of player
    local giftPos = playerPos + direction * 5 + Vector3.new(0, 1, 0)
    
    -- Remove old gift if exists
    if currentGift then
        currentGift:Destroy()
    end
    
    -- Create gift model
    local gift = Instance.new("Model")
    gift.Name = "CouplesGift"
    
    -- Gift box (red with pink accents)
    local box = Instance.new("Part")
    box.Size = Vector3.new(4, 4, 4)
    box.Position = giftPos
    box.Anchored = true
    box.BrickColor = BrickColor.new(Color3.fromRGB(255, 50, 50)) -- Red
    box.Material = Enum.Material.SmoothPlastic
    box.Parent = gift
    
    -- Gift lid (pink)
    local lid = Instance.new("Part")
    lid.Size = Vector3.new(4.2, 0.8, 4.2)
    lid.Position = giftPos + Vector3.new(0, 2.2, 0)
    lid.Anchored = true
    lid.BrickColor = BrickColor.new(Color3.fromRGB(255, 105, 180)) -- Pink
    lid.Material = Enum.Material.SmoothPlastic
    lid.Parent = gift
    
    -- Gold ribbon (horizontal)
    local ribbonH = Instance.new("Part")
    ribbonH.Size = Vector3.new(4.5, 0.3, 0.3)
    ribbonH.Position = giftPos
    ribbonH.Anchored = true
    ribbonH.BrickColor = BrickColor.new(Color3.fromRGB(255, 215, 0)) -- Gold
    ribbonH.Material = Enum.Material.Neon
    ribbonH.Parent = gift
    
    -- Gold ribbon (vertical)
    local ribbonV = Instance.new("Part")
    ribbonV.Size = Vector3.new(0.3, 4.5, 0.3)
    ribbonV.Position = giftPos
    ribbonV.Anchored = true
    ribbonV.BrickColor = BrickColor.new(Color3.fromRGB(255, 215, 0))
    ribbonV.Material = Enum.Material.Neon
    ribbonV.Parent = gift
    
    -- Bow
    local bow1 = Instance.new("Part")
    bow1.Size = Vector3.new(1, 0.4, 0.4)
    bow1.Position = giftPos + Vector3.new(1.5, 2.5, 0)
    bow1.Anchored = true
    bow1.BrickColor = BrickColor.new(Color3.fromRGB(255, 215, 0))
    bow1.Material = Enum.Material.Neon
    bow1.Orientation = Vector3.new(0, 45, 0)
    bow1.Parent = gift
    
    local bow2 = Instance.new("Part")
    bow2.Size = Vector3.new(1, 0.4, 0.4)
    bow2.Position = giftPos + Vector3.new(-1.5, 2.5, 0)
    bow2.Anchored = true
    bow2.BrickColor = BrickColor.new(Color3.fromRGB(255, 215, 0))
    bow2.Material = Enum.Material.Neon
    bow2.Orientation = Vector3.new(0, -45, 0)
    bow2.Parent = gift
    
    -- Heart decorations
    for i = 1, 4 do
        local heart = Instance.new("Part")
        heart.Size = Vector3.new(0.5, 0.5, 0.5)
        heart.Position = giftPos + Vector3.new(math.random(-1.5, 1.5), 0.5, math.random(-1.5, 1.5))
        heart.Anchored = true
        heart.BrickColor = BrickColor.new(Color3.fromRGB(255, 105, 180))
        heart.Material = Enum.Material.Neon
        heart.Parent = gift
    end
    
    gift.Parent = workspace
    
    -- Store current gift
    currentGift = gift
    
    -- Show open button
    openBtn.Visible = true
    statusLabel.Text = "Gift spawned! Click OPEN GIFT"
    
    return gift
end

local function openCouplesGift()
    if not currentGift then
        statusLabel.Text = "No gift to open! Spawn one first."
        return
    end
    
    statusLabel.Text = "Opening gift..."
    
    -- Get gift position
    local giftPos = currentGift:GetPivot().Position
    
    -- Find lid and box
    local lid = nil
    local box = nil
    for _, child in pairs(currentGift:GetChildren()) do
        if child:IsA("Part") then
            if child.Size.Y > 3 then
                box = child
            elseif child.Size.Y < 1 and child.Size.X > 4 then
                lid = child
            end
        end
    end
    
    -- Animate lid opening
    if lid then
        local tween = TweenService:Create(lid, TweenInfo.new(0.8, Enum.EasingStyle.Back), {
            Position = giftPos + Vector3.new(0, 5, 2)
        })
        tween:Play()
    end
    
    -- Heart particle effect
    local hearts = Instance.new("ParticleEmitter")
    hearts.Texture = "rbxasset://textures/particles/sparkles_main.dds"
    hearts.Rate = 50
    hearts.Lifetime = NumberRange.new(2)
    hearts.Speed = NumberRange.new(2, 5)
    hearts.SpreadAngle = Vector2.new(360, 360)
    hearts.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 105, 180)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0))
    })
    hearts.Parent = box or currentGift
    
    task.wait(0.5)
    
    -- Select random pet
    local petData = AllPets[math.random(1, #AllPets)]
    
    -- Create properties
    local properties = {
        pet_trick_level = 5,
        age = math.random(1, 6),
        ailments_completed = 0,
        rp_name = GenerateUniquePetName(),
        flyable = true,
        rideable = true,
        mega_neon = false,
        neon = false
    }
    
    -- Create inventory item
    CreateInventoryItem(petData.id, "pets", properties)
    
    -- Load pet model
    local model = FetchPetModel(petData.kind)
    
    if not model then
        -- Fallback model
        model = Instance.new("Model")
        model.Name = petData.name
        
        local part = Instance.new("Part")
        part.Size = Vector3.new(2, 2, 2)
        part.BrickColor = BrickColor.new(Color3.fromRGB(255, 105, 180))
        part.Parent = model
        model.PrimaryPart = part
    else
        model:ScaleTo(1.2)
    end
    
    -- Position pet rising from box
    model:SetPrimaryPartCFrame(CFrame.new(giftPos + Vector3.new(0, 1, 0)))
    model.Parent = workspace
    
    -- Rising animation
    local riseTween = TweenService:Create(model, TweenInfo.new(1, Enum.EasingStyle.Quad), {
        CFrame = CFrame.new(giftPos + Vector3.new(0, 4, 0))
    })
    riseTween:Play()
    
    -- Add floating animation
    spawn(function()
        local baseY = 4
        local time = 0
        while model and model.Parent do
            time = time + 0.05
            local yOffset = math.sin(time) * 0.3
            model:SetPrimaryPartCFrame(CFrame.new(giftPos + Vector3.new(0, baseY + yOffset, 0)))
            task.wait(0.05)
        end
    end)
    
    -- Add "Happy Couples Day!" text
    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = model.PrimaryPart or model
    
    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1, 0, 1, 0)
    text.BackgroundTransparency = 1
    text.Text = "❤️ HAPPY COUPLES DAY! ❤️"
    text.TextColor3 = Color3.fromRGB(255, 105, 180)
    text.TextScaled = true
    text.Font = Enum.Font.GothamBold
    text.Parent = billboard
    
    -- Add heart particles around pet
    local petHearts = Instance.new("ParticleEmitter")
    petHearts.Texture = "rbxasset://textures/particles/sparkles_main.dds"
    petHearts.Rate = 20
    petHearts.Lifetime = NumberRange.new(1.5)
    petHearts.Speed = NumberRange.new(1, 2)
    petHearts.Color = ColorSequence.new(Color3.fromRGB(255, 105, 180))
    petHearts.Parent = model.PrimaryPart or model
    
    -- Highlight pet
    local highlight = Instance.new("Highlight")
    highlight.Adornee = model
    highlight.FillColor = Color3.fromRGB(255, 105, 180)
    highlight.FillTransparency = 0.3
    highlight.OutlineColor = Color3.fromRGB(255, 0, 0)
    highlight.Parent = model
    
    -- Fade out gift box
    for _, child in pairs(currentGift:GetChildren()) do
        if child:IsA("Part") then
            local fade = TweenService:Create(child, TweenInfo.new(1), {Transparency = 1})
            fade:Play()
        end
    end
    
    -- Update counters
    giftCount = giftCount + 1
    countLabel.Text = "Gifts opened: " .. giftCount
    statusLabel.Text = "You got: " .. petData.name .. "! ❤️"
    
    -- Hide open button
    openBtn.Visible = false
    
    -- Clean up
    Debris:AddItem(currentGift, 2)
    Debris:AddItem(model, 45)
    Debris:AddItem(hearts, 3)
    Debris:AddItem(petHearts, 3)
    Debris:AddItem(highlight, 5)
    
    currentGift = nil
end

